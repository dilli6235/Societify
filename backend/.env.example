# ──────────────────────────────────────────────────────────────
#  Server
# ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ──────────────────────────────────────────────────────────────
#  Database (PostgreSQL)
#  Two URLs: the app connects as a NON-superuser so RLS is enforced.
# ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://society_app:app_password@localhost:5432/society_saas?schema=public

# ──────────────────────────────────────────────────────────────
#  Redis (BullMQ background jobs)
# ──────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ──────────────────────────────────────────────────────────────
#  Auth / JWT
#  Generate with: openssl rand -base64 48
# ──────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=replace_me_with_long_random_string
JWT_REFRESH_SECRET=replace_me_with_a_different_long_random_string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ──────────────────────────────────────────────────────────────
#  Cookies
# ──────────────────────────────────────────────────────────────
COOKIE_SECRET=replace_me_with_random_string
REFRESH_COOKIE_NAME=society_rt

# ──────────────────────────────────────────────────────────────
#  Rate limiting
# ──────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# ──────────────────────────────────────────────────────────────
#  Payments (Razorpay). Leave blank to disable online payments;
#  manual (cash/cheque/bank) recording still works.
# ──────────────────────────────────────────────────────────────
PAYMENT_PROVIDER=razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ──────────────────────────────────────────────────────────────
#  Notifications. Each channel is skipped if its config is blank.
#  In-app notifications always persist. Push needs FCM; email needs a from-addr.
# ──────────────────────────────────────────────────────────────
FCM_SERVER_KEY=
EMAIL_FROM=
# Real SMTP. Leave ALL blank in dev to auto-use an Ethereal test inbox (the API
# logs a preview URL per email). For Gmail, set SMTP_USER + SMTP_PASS below:
#   SMTP_USER = your full Gmail address
#   SMTP_PASS = a 16-char Google App Password (Account → Security → App passwords)
#   EMAIL_FROM = your Gmail address (recommended)
SMTP_URL=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ──────────────────────────────────────────────────────────────
#  Web dashboard URL (for invite/activation links in emails)
# ──────────────────────────────────────────────────────────────
WEB_APP_URL=http://localhost:5173
